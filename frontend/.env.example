NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Supabase Auth (0.6.0). Public, client-safe values from your Supabase project's API settings.
# When both are set, real sign-in (OAuth + magic link) is enabled and the verified token is
# attached to every backend request. Leave unset to run in dev mode (see below).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev mode: when "true", the X-Dev-Actor-Id actor switcher is shown for local work without an
# IdP. It is INERT unless the backend also sets AUTH_DEV_HEADER_ENABLED=true, so this alone grants
# no access — but always leave it unset/false in production (the backend flag is the real gate).
NEXT_PUBLIC_AUTH_DEV=true
