APP_ENV=local
APP_NAME=OpenTheory API
API_V1_PREFIX=/api/v1

# App connection. Locally this is a plain local Postgres. In production, point it at the
# Supabase TRANSACTION POOLER (port 6543) with the asyncpg driver and ssl=require, e.g.:
#   postgresql+asyncpg://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opentheory

# Optional separate connection used ONLY by Alembic migrations — DDL + schema introspection
# prefer a stable, non-pooled session. In production this is the Supabase DIRECT connection
# (port 5432). Falls back to DATABASE_URL when unset.
#   MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres?ssl=require

# Comma-separated allowed browser origins (no trailing slash). In production this is your
# deployed frontend URL, e.g. https://opentheory.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Auth (0.6.0; ES256/JWKS since 0.7.x) -----------------------------------------------
# The backend only verifies the Supabase-issued session JWT and reads its claims (Decision #2).
# Supabase signs sessions with ES256 (asymmetric) and publishes the public keys at the project's
# JWKS endpoint; the backend fetches the signing key by `kid` from there — no shared secret.
# Set SUPABASE_PROJECT_URL (public; same value as the frontend's NEXT_PUBLIC_SUPABASE_URL); the
# JWKS URL is derived as <url>/auth/v1/.well-known/jwks.json.
SUPABASE_PROJECT_URL=https://<ref>.supabase.co
# Override the derived JWKS endpoint directly (optional; takes precedence over PROJECT_URL).
# SUPABASE_JWKS_URL=
# Expected `aud` claim. Supabase signs signed-in users with aud="authenticated".
SUPABASE_JWT_AUDIENCE=authenticated

# When true, the legacy X-Dev-Actor-Id header path stays active (local + tests) so writes work
# without an IdP. MUST be false in production — then only a verified bearer token is accepted.
AUTH_DEV_HEADER_ENABLED=true

# Comma-separated emails granted the `internal` (Kamino) role on first sign-in (JIT). The
# internal role gates native funding. Compared case-insensitively. e.g. you@kamino.ai
INTERNAL_ACTOR_EMAILS=
